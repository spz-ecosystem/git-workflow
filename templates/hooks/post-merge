#!/bin/bash
# Git Workflow Umbrella Skill - post-merge 钩子
# 在合并后执行操作

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 日志函数
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_info "执行 post-merge 钩子..."

# 获取合并的提交
merge_commit=$(git rev-parse HEAD)
merge_message=$(git log -1 --pretty=%B)

log_info "合并提交: $merge_commit"
log_info "合并消息: $merge_message"

# 检查是否是合并提交
if ! git rev-parse -q --verify HEAD^2 > /dev/null; then
    log_info "不是合并提交，跳过"
    exit 0
fi

# 获取合并的分支
merged_branch=$(git name-rev --name-only HEAD^2)
log_info "合并的分支: $merged_branch"

# 检查是否是功能分支合并
if [[ "$merged_branch" == feature/* ]]; then
    log_info "检测到功能分支合并: $merged_branch"
    
    # 这里可以添加功能分支合并后的操作
    # 例如：更新文档、运行测试、部署等
fi

# 检查是否是 bugfix 分支合并
if [[ "$merged_branch" == bugfix/* ]]; then
    log_info "检测到 bugfix 分支合并: $merged_branch"
    
    # 这里可以添加 bugfix 分支合并后的操作
    # 例如：运行测试、通知相关人员等
fi

# 检查是否是 hotfix 分支合并
if [[ "$merged_branch" == hotfix/* ]]; then
    log_info "检测到 hotfix 分支合并: $merged_branch"
    
    # 这里可以添加 hotfix 分支合并后的操作
    # 例如：部署到生产环境、通知相关人员等
fi

# 检查是否是 release 分支合并
if [[ "$merged_branch" == release/* ]]; then
    log_info "检测到 release 分支合并: $merged_branch"
    
    # 这里可以添加 release 分支合并后的操作
    # 例如：打标签、部署、通知等
fi

# 更新依赖（可选）
# 这里可以添加更新依赖的逻辑
# 例如：npm install、pip install 等

# 检查依赖更新
if [ -f "package.json" ]; then
    log_info "检测到 package.json，检查依赖更新..."
    # npm install
fi

if [ -f "requirements.txt" ]; then
    log_info "检测到 requirements.txt，检查依赖更新..."
    # pip install -r requirements.txt
fi

if [ -f "Pipfile" ]; then
    log_info "检测到 Pipfile，检查依赖更新..."
    # pipenv install
fi

# 运行构建（可选）
# 这里可以添加运行构建的逻辑
# 例如：npm run build、python setup.py build 等

# 检查构建文件
if [ -f "Makefile" ]; then
    log_info "检测到 Makefile，运行构建..."
    # make build
fi

if [ -f "CMakeLists.txt" ]; then
    log_info "检测到 CMakeLists.txt，运行构建..."
    # cmake --build build
fi

# 运行测试（可选）
# 这里可以添加运行测试的逻辑
# 例如：npm test、pytest 等

# 检查测试配置
if [ -f "jest.config.js" ] || [ -f "jest.config.ts" ]; then
    log_info "检测到 Jest 配置，运行测试..."
    # npm test
fi

if [ -f "pytest.ini" ] || [ -f "pyproject.toml" ]; then
    log_info "检测到 pytest 配置，运行测试..."
    # pytest
fi

# 清理工作区（可选）
# 这里可以添加清理工作区的逻辑
# 例如：清理临时文件、重置状态等

# 清理临时文件
if [ -d "tmp" ]; then
    log_info "清理临时文件..."
    # rm -rf tmp/*
fi

# 重置文件权限
log_info "重置文件权限..."
# chmod -R 755 .

# 显示合并后的状态
log_info "合并后的状态:"
git status --short

# 显示最近的提交
log_info "最近的提交:"
git log --oneline -5

log_success "post-merge 钩子执行完成"

# 成功退出
exit 0