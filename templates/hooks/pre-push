#!/bin/bash
# Git Workflow Umbrella Skill - pre-push 钩子
# 在推送前执行检查

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 日志函数
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

# 获取远程和本地引用
local_ref=$(git rev-parse "$1")
remote_ref=$(git rev-parse "$2")
remote_name="$3"

log_info "执行 pre-push 钩子..."
log_info "本地引用: $local_ref"
log_info "远程引用: $remote_ref"
log_info "远程名称: $remote_name"

# 检查是否推送到主分支
current_branch=$(git rev-parse --abbrev-ref HEAD)
protected_branches=("main" "master" "develop" "release" "production")

for branch in "${protected_branches[@]}"; do
    if [[ "$current_branch" == "$branch" ]]; then
        log_warn "正在推送到保护分支: $current_branch"
        log_warn "请确保您有权限推送到此分支"
        
        # 可以在这里添加额外的检查
        # 例如：检查是否有 PR、是否通过测试等
    fi
done

# 检查提交消息
commit_message=$(git log -1 --pretty=%B)
if [[ -z "$commit_message" ]]; then
    log_error "提交消息为空"
    exit 1
fi

# 检查提交消息格式
if ! echo "$commit_message" | grep -qE "^(feat|fix|docs|style|refactor|perf|test|chore)(\(.+\))?: .{1,}"; then
    log_warn "提交消息格式不符合规范"
    log_warn "推荐格式: <type>(<scope>): <subject>"
    log_warn "例如: feat(push): 添加推送前预检功能"
fi

# 检查是否有未提交的更改
if ! git diff --quiet; then
    log_warn "有未提交的更改"
    git diff --stat
fi

# 检查是否有未暂存的更改
if ! git diff --cached --quiet; then
    log_warn "有未暂存的更改"
    git diff --cached --stat
fi

# 执行代码检查（可选）
# 这里可以添加您的代码检查逻辑
# 例如：ESLint、Pylint、测试等

# 检查是否有敏感信息
sensitive_patterns=(
    "password"
    "secret"
    "api_key"
    "token"
    "private_key"
)

for pattern in "${sensitive_patterns[@]}"; do
    if git diff --cached --diff-filter=ACM | grep -i "$pattern"; then
        log_error "检测到可能的敏感信息: $pattern"
        log_error "请检查您的代码，确保没有泄露敏感信息"
        exit 1
    fi
done

# 检查文件大小
large_files=$(git diff --cached --diff-filter=ACM --name-only | xargs -I {} sh -c 'if [ -f "{}" ]; then size=$(wc -c < "{}"); if [ "$size" -gt 1048576 ]; then echo "{} ($size bytes)"; fi; fi')
if [ -n "$large_files" ]; then
    log_warn "检测到大文件:"
    echo "$large_files"
    log_warn "请考虑使用 Git LFS 管理大文件"
fi

log_success "pre-push 钩子检查通过"

# 允许推送
exit 0